<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nestora</title>
</head>
<body>
    <form method="POST" action="/listings">
        <h3>Create New Listing</h3>
        <input name="listing[title]" placeholder="Enter Title">
        <br> <br>
        <textarea name="listing[description]" placeholder="Enter description"></textarea>
        <br><br>
        <input name="listing[image]" placeholder="Enter image URL/Link">
        <br><br>

        <input name="listing[price]" placeholder="Enter Price">
        <br><br>
        <input name="listing[location]" placeholder="Enter Location">
        <br><br>
        <input name="listing[country]" placeholder="Enter Country name">
        <br><br>
        <button>Add</button>
    </form>
</body>
</html>